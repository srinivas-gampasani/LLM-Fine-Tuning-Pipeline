# ============================================================
#  LLM Fine-Tuning Pipeline — Environment Variables
# ============================================================

# HuggingFace token (for gated models like Llama 2 and Hub publishing)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Weights & Biases (experiment tracking)
# Get yours at: https://wandb.ai/settings
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=llm-finetuning-pipeline

# Model serving (inference server)
ADAPTER_PATH=outputs/checkpoints/lora_adapter
BASE_MODEL=meta-llama/Llama-2-7b-hf

# CUDA settings
CUDA_VISIBLE_DEVICES=0
TOKENIZERS_PARALLELISM=false
